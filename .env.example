# ============ 主推理 LLM ============
# 可选: deepseek | qwen | openrouter | minimax | local
LLM_PROVIDER=openrouter
# 可选：强制指定模型，留空则用该 provider 的默认模型
# LLM_MODEL=

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenRouter（完全 OpenAI 兼容，可路由到 MiniMax 等模型）
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MiniMax 官方（国内 api.minimax.chat；国际把 BASE_URL 改成 https://api.minimaxi.com/v1）
MINIMAX_API_KEY=xxxxxxxxxxxxxxxx
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ============ 联网检索（web_search）============
# Agent 的 web_search 工具复用 MiniMax coding-plan MCP（uvx minimax-coding-plan-mcp）。
# 需上面的 MINIMAX_API_KEY，外加 MCP 的 API HOST：
MINIMAX_API_HOST=https://api.minimaxi.com
# 设 WEB_SEARCH=0 可关闭联网检索；如需自定义 MCP 启动命令可覆盖下面两项
# MINIMAX_MCP_COMMAND=uvx
# MINIMAX_MCP_ARGS=minimax-coding-plan-mcp -y

# 本地 Ollama
LOCAL_MODEL=qwen2.5:7b
# LOCAL_BASE_URL=http://localhost:11434/v1

# ============ 多模态视觉（照片/原理图理解）============
# 视觉工具单独选 provider，默认走 OpenRouter→MiniMax
VISION_PROVIDER=openrouter
# OpenRouter 上的 MiniMax 视觉模型 id；用官方 minimax 时设为 MiniMax-VL-01
VISION_MODEL=minimax/minimax-01

# ============ EDA 工具后端 ============
# bridge：本仓库 bridge/server.py 直接实现官方 mcp-bridge 的桥接协议，
#         由嘉立创EDA里的官方 mcp-bridge 插件拨入 → 真连真 EDA（推荐，无需自建扩展）。
#         离线时用 bridge/mock_bridge.py 顶替插件做联调/演示。
# mcp   ：Agent 作为 MCP Client 连一个独立的 MCP Server（可选，见下方）。
TOOL_BACKEND=bridge

# --- TOOL_BACKEND=bridge 时生效 ---
# 本服务监听地址；EDA 的 mcp-bridge 插件「桥接地址」要设成 ws://<host>:<port>/bridge/ws
BRIDGE_HOST=127.0.0.1
# 注意：官方默认 8765，但本机被百度输入法占用，已改用 8799；两端保持一致即可
BRIDGE_PORT=8799

# --- TOOL_BACKEND=mcp 时生效（连独立 MCP Server，如 hyl64/jlcmcp）---
# 传输方式：stdio（把 server 当子进程拉起）| http | sse
MCP_TRANSPORT=stdio
# stdio：启动命令与参数（按你装的 server 实际命令填）
# MCP_COMMAND=npx
# MCP_ARGS=-y some-jlceda-mcp-server
# http/sse：MCP 服务地址
# MCP_URL=http://127.0.0.1:3000/mcp

# ============ Agent 配置 ============
MAX_STEPS=10
MAX_HISTORY=20
